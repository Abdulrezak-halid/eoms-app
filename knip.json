{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignore": [
    "packages/app/i18n-unused.config.cjs",
    "packages/app/src/i18next.d.ts",
    "packages/common/api-schema.d.ts"
  ],
  "workspaces": {
    "packages/*": {
      "paths": {
        "@/*": [
          "./src/*"
        ],
        "@m/*": [
          "./src/modules/*"
        ]
      }
    }
  }
}
