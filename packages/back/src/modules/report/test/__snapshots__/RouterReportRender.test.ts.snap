exports[`E2E - RouterReportRender > report layout 1`] = `
"<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Factory Energy Consumption Report</title>
  </head>
  <body>
    <table class="report-header-table">
      <thead>
        <tr>
          <td>
            <div class="report-header">
              <div>
                Factory Energy Consumption Report - Example Organization
              </div>
              <div>Reneryo</div>
            </div>
          </td>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>
            <div class="content">
              <h1>Factory Energy Consumption Report</h1>
              <div id="report-period-info">
                {dateStartPeriod}: 8/1/2025 - {dateEndPeriod}: 8/31/2025
              </div>
              <div id="authors">
                <h2>{authors}:</h2>
                <ul>
                  <li>admin</li>
                </ul>
              </div>
              <div id="table-of-contents">
                <h2>{tableOfContents}</h2>
                <ul>
                  <li><a href="#section-1">1. Overview</a></li>
                  <li>
                    <a href="#section-1.1">1.1. Total Energy Consumption</a>
                  </li>
                  <li>
                    <a href="#section-1.1.1">1.1.1. Breakdown by Source</a>
                  </li>
                  <li>
                    <a href="#section-2">2. Energy Efficiency Measures</a>
                  </li>
                  <li><a href="#section-2.1">2.1. Lighting Upgrade</a></li>
                  <li><a href="#section-2.1.1">2.1.1. Expected Savings</a></li>
                  <li><a href="#section-3">3. Recommendations</a></li>
                </ul>
              </div>
              <div id="section-1" class="section">
                <div class="section-title">1. Overview</div>
                <p>
                  This report provides a detailed overview of the energy
                  consumption and efficiency of our main manufacturing plant for
                  August 2025.
                </p>
              </div>
              <div id="section-1.1" class="section">
                <div class="section-title">1.1. Total Energy Consumption</div>
                <p>
                  The factory consumed a total of 1,250,000 kWh during the
                  reporting period, representing a 5% increase compared to July
                  2025.
                </p>
              </div>
              <div id="section-1.1.1" class="section">
                <div class="section-title">1.1.1. Breakdown by Source</div>
                <p>
                  Electricity: 800,000 kWh, Natural Gas: 350,000 kWh, Solar:
                  100,000 kWh.
                </p>
              </div>
              <div id="section-2" class="section">
                <div class="section-title">2. Energy Efficiency Measures</div>
                <p>
                  Several measures were implemented to reduce energy
                  consumption, including upgrading lighting systems and
                  optimizing machinery operation schedules.
                </p>
              </div>
              <div id="section-2.1" class="section">
                <div class="section-title">2.1. Lighting Upgrade</div>
                <p>
                  Replaced all high-consumption bulbs with LED alternatives,
                  reducing electricity use in production halls by 12%.
                </p>
              </div>
              <div id="section-2.1.1" class="section">
                <div class="section-title">2.1.1. Expected Savings</div>
                <p>Projected annual savings: 50,000 kWh and $6,000.</p>
              </div>
              <div id="section-3" class="section">
                <div class="section-title">3. Recommendations</div>
                <p>
                  Further efficiency improvements can be achieved through
                  automated energy monitoring, employee training, and investment
                  in renewable energy sources.
                </p>
              </div>
            </div>
          </td>
        </tr>
      </tbody>
    </table>
  </body>
</html>
"
`;

