{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "strict": true,
    // "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "paths": {
      "@m/*": [
        "./src/modules/*"
      ],
      "@/*": [
        "./src/*"
      ]
    },
    "outDir": "dist"
  },
  "include": [
    "src"
  ]
}
