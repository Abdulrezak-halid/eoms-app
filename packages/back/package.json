{
  "name": "back",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch --tsconfig tsconfig.app.json --import ./misc/open-telemetry-instrumentations.ts src/index.ts",
    "build:api-json": "NODE_ENV=development MODE_EXPORT_API_SCHEMA=true tsx --tsconfig tsconfig.app.json src/index.ts",
    "build:preview": "DB_MIG_DIR=migrations.preview npm run _mig:gen && npm run _build && cp -r migrations.preview dist",
    "build:prod": "npm run _build && cp -r migrations.prod dist",
    "analyze:prod": "ESBUILD_METAFILE=/tmp/reneryo-build-meta.json npm run _build-core && esbuild-visualizer --metadata /tmp/reneryo-build-meta.json --filename /tmp/reneryo-analyze-stats.html && xdg-open /tmp/reneryo-analyze-stats.html",
    "_build-core": "rm -rf dist && NODE_ENV=production node build.mjs",
    "_build": "npm run _build-core && mkdir -p dist/node_modules && cp -r ../../node_modules/@img dist/node_modules/ && cp -r misc/vega-canvas/ dist/node_modules/",
    "check:lint": "eslint --max-warnings 0",
    "check:ts": "tsc -p tsconfig.app.json --noEmit",
    "check:all": "npm run check:ts && npm run check:lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:cover": "vitest run --coverage",
    "recreate-all-storages": "tsx --tsconfig tsconfig.node.json ./misc/recreate-all-storages.ts",
    "mig:regen:local": "rm -rf migrations.dev && npm run mig:gen:local && npm run recreate-all-storages",
    "mig:gen:local": "DB_MIG_DIR=migrations.dev npm run _mig:gen",
    "mig:gen:prod": "DB_MIG_DIR=migrations.prod npm run _mig:gen",
    "_mig:gen": "tsx --tsconfig tsconfig.app.json ../../node_modules/.bin/drizzle-kit generate --dialect postgresql --out $DB_MIG_DIR --schema=src/modules/*/orm",
    "mig:apply:local": "drizzle-kit migrate",
    "mig:sys:local": "curl \"http://localhost:3000/s/migrate\" -H X-Token:DUMMY -w \"\\n\"",
    "i18n:fetch": "./scripts/i18n-fetch.sh",
    "i18n:integrate-static": "./scripts/i18n-integrate-static.sh"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.1.0",
    "@aws-sdk/client-s3": "^3.879.0",
    "@hono/node-server": "^1.19.1",
    "@hono/node-ws": "^1.2.0",
    "@hono/otel": "^0.5.0",
    "@hono/swagger-ui": "^0.5.2",
    "@hono/zod-openapi": "^1.1.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.203.0",
    "@opentelemetry/instrumentation-amqplib": "^0.52.3",
    "@opentelemetry/instrumentation-pg": "^0.56.1",
    "@opentelemetry/instrumentation-undici": "^0.14.0",
    "@opentelemetry/sdk-node": "^0.203.0",
    "@tolgee/web": "^6.2.7",
    "amqplib": "^0.10.9",
    "common": "^1.0.0",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.44.5",
    "exceljs": "^4.4.0",
    "hono": "^4.9.6",
    "ml-regression-multivariate-linear": "^2.0.4",
    "node-forge": "^1.3.1",
    "node-schedule": "^2.1.1",
    "nodemailer": "^8.0.4",
    "pg": "^8.16.3",
    "pino": "^9.9.1",
    "pino-loki": "^2.6.0",
    "pino-pretty": "^13.1.1",
    "sharp": "^0.34.3",
    "simple-statistics": "^7.8.8",
    "undici": "^7.15.0",
    "vega": "^6.1.2",
    "xxhash-wasm": "^1.1.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.7",
    "@eslint/js": "^9.34.0",
    "@types/amqplib": "^0.10.7",
    "@types/node": "^24.3.0",
    "@types/node-forge": "^1.3.14",
    "@types/node-schedule": "^2.1.8",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.15.5",
    "@vitest/coverage-istanbul": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "drizzle-kit": "^0.31.4",
    "esbuild": "^0.25.0",
    "esbuild-visualizer": "^0.7.0",
    "eslint": "^9.34.0",
    "openapi-fetch": "^0.14.0",
    "opentelemetry-esbuild-plugin-node": "^4.4.0",
    "prettier": "^3.6.2",
    "tslib": "^2.8.1",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.42.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "version": "1.0.0",
  "description": "``` npm install npm run dev ```",
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
