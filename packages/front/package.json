{
  "name": "front",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "check:lint": "eslint --max-warnings 0",
    "check:ts": "tsc --noEmit -p tsconfig.app.json",
    "check:all": "npm run check:ts && npm run check:lint",
    "preview": "vite preview",
    "analyze:dev": "vite-bundle-visualizer --mode development",
    "analyze:prod": "vite-bundle-visualizer",
    "build:dev": "NODE_ENV=development vite build --mode development",
    "build:prod": "vite build",
    "integrate-static-translations": "./misc/integrate-static-translations.sh",
    "test": "vitest run",
    "i18n:fetch": "./scripts/i18n-fetch.sh",
    "i18n:integrate-static": "./scripts/i18n-integrate-static.sh"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.16",
    "@hcaptcha/react-hcaptcha": "^1.14.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@tailwindcss/vite": "^4.1.12",
    "@tolgee/react": "^6.2.7",
    "@tolgee/web": "^6.2.7",
    "chart.js": "^4.5.0",
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-plugin-datalabels": "^2.2.0",
    "common": "^1.0.0",
    "date-fns": "^4.1.0",
    "highlight.js": "^11.11.1",
    "json-edit-react": "^1.28.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.562.0",
    "mermaid": "^11.14.0",
    "openapi-fetch": "^0.14.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-error-boundary": "^6.0.0",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-world-flags": "^2.0.0-beta.4",
    "tailwindcss": "^4.1.12",
    "wouter": "^3.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@eslint/json": "^0.13.2",
    "@tolgee/cli": "^2.14.0",
    "@types/leaflet": "^1.9.20",
    "@types/react": "^19.1.12",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.34.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0",
    "unplugin-inject-preload": "^3.0.0",
    "vite": "^7.1.4",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "description": "This template provides a minimal setup to get React working in Vite with HMR and some ESLint rules.",
  "main": "eslint.config.js",
  "keywords": [],
